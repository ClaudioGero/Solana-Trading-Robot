    "sell_dust_alert_ttl_seconds": 600
  },
  "providers": {
    "rpc": {
      "primary": "https://api.mainnet-beta.solana.com",
      "ws": "wss://api.mainnet-beta.solana.com"
    },
    "jupiter": {
      "base_url": "https://api.jup.ag"
    },
    "jito": {
      "enabled": false,
      "max_tip_sol": 0.0,
      "max_priority_fee_sol": 0.0
    }
