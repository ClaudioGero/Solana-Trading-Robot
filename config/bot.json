{
  "version": 1,
  "mode": {
    "dry_run": true,
    "simulate_only": true
  },
  "copytrade": {
    "fixed_buy_sol": 0.1
  },
  "exits": {
    "mode": "basic",
    "basic": {
      "take_profit_pct": 10.0,
      "stop_loss_pct": 10.0,
      "sell_percent_on_take_profit": 100.0,
      "sell_percent_on_stop_loss": 100.0
    }
  },
  "risk": {
    "max_concurrent_positions_global": null,
    "max_concurrent_positions_per_wallet": null
  },
  "filters": {
    "enabled": true,
    "only_buys": true,
    "allowed_venues": ["jupiter", "unknown"],
    "min_notional_sol": 0.1,
    "min_market_cap_usd": null,
    "max_market_cap_usd": null
  },
  "executor": {
    "enabled": false,
    "slippage_bps": 500,
