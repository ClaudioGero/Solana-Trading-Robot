{
  "name": "solana-bot-control",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build && npm run start",
    "dev:watch": "tsc -p tsconfig.json --watch",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "wallets:analyze": "npm run build && node dist/walletAnalysisCli.js",
    "control:bot": "ts-node --esm src/controlBot.ts",
    "start:control:bot": "node dist/controlBot.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "grammy": "^1.38.3",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "redis": "^5.8.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
