# Control plane env (safe template). Copy to control/.env on your machine.

PORT=8787
CONTROL_BIND=
LOG_LEVEL=info

# Shared state (later blocks)
REDIS_URL=redis://127.0.0.1:6379
DATABASE_URL=postgres://bot:bot@127.0.0.1:5432/bot

# Config files
ALPHA_WALLETS_PATH=../config/alpha_wallets.json
BOT_CONFIG_PATH=../config/bot.json

# Telegram control bot
CONTROL_TELEGRAM_BOT_TOKEN=
CONTROL_ADMIN_USER_ID=
CONTROL_CHAT_ID=

# Alerting (later blocks)
SLACK_WEBHOOK_URL=

# Research providers
BIRDEYE_API_KEY=
HELIUS_API_KEY=
MOBULA_API_KEY=
X_BEARER_TOKEN=
TWITTERAPI_IO_KEY=
DEXSCREENER_BASE_URL=https://api.dexscreener.com
BIRDEYE_BASE_URL=https://public-api.birdeye.so
HELIUS_API_BASE_URL=https://mainnet.helius-rpc.com
MOBULA_API_BASE_URL=https://api.mobula.io
X_API_BASE_URL=https://api.twitter.com/2
TWITTERAPI_IO_BASE_URL=https://api.twitterapi.io/twitter/community
