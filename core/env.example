# === Providers ===
# Start with Helius free tier later; for now mainnet public endpoint is ok for scaffolding.
RPC_HTTP_URL=https://api.mainnet-beta.solana.com
RPC_WS_URL=wss://api.mainnet-beta.solana.com

# Optional (later blocks)
HELIUS_API_KEY=
JUPITER_API_KEY=
BIRDEYE_API_KEY=
JITO_BUNDLE_ENDPOINT=
JITO_RPC_ENDPOINT=

# If you use Helius WS, set RPC_WS_URL to:
# wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# === Runtime ===
ALPHA_WALLETS_PATH=../config/alpha_wallets.json
BOT_CONFIG_PATH=../config/bot.json

# === Signing (v1 local keypair) ===
# Point to a local Solana keypair file (JSON array of 64 bytes)
KEYPAIR_PATH=

# === State ===
REDIS_URL=redis://127.0.0.1:6379
DATABASE_URL=postgres://bot:bot@127.0.0.1:5432/bot
DB_ENABLED=false

# === Safety switches ===
DRY_RUN=true 
SIMULATE_ONLY=true
